# Copy this file to .env.production on the server and replace every placeholder.
# Never commit real production secrets.

PROJECT_NAME=Lankside API
ENVIRONMENT=production

POSTGRES_USER=lankside
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_POSTGRES_PASSWORD
POSTGRES_DB=lankside_db
DATABASE_URL=postgresql://lankside:REPLACE_WITH_STRONG_POSTGRES_PASSWORD@postgres:5432/lankside_db

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

BACKEND_CORS_ORIGINS=https://your-domain.example
NEXT_PUBLIC_API_URL=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
EXTRACTION_USE_AI=false

PINECONE_API_KEY=
PINECONE_INDEX_NAME=lankside-schemes
PINECONE_ENVIRONMENT=
GRANT_SCOUT_USE_VECTOR=false

UPLOAD_DIR=/app/uploads
MOU_PDF_DIR=/app/uploads/mous
REPORT_OUTPUT_DIR=/app/uploads/reports
REPORT_PDF_DIR=/app/uploads/reports
MAX_UPLOAD_SIZE_MB=10

ADMIN_DEMO_ENABLED=false
PYTHONUNBUFFERED=1
NEXT_TELEMETRY_DISABLED=1
