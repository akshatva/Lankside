PROJECT_NAME=Lankside API
ENVIRONMENT=local
POSTGRES_USER=lankside
POSTGRES_PASSWORD=lankside_password
POSTGRES_DB=lankside_db
# Docker Compose uses the postgres service hostname.
DATABASE_URL=postgresql://lankside:lankside_password@postgres:5432/lankside_db
# For running backend directly on the host, use localhost instead:
# DATABASE_URL=postgresql://lankside:lankside_password@localhost:5432/lankside_db
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
BACKEND_CORS_ORIGINS=http://localhost:3000
BACKEND_PORT=8000
FRONTEND_PORT=3000
BACKEND_API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=/api/backend
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
EXTRACTION_USE_AI=false
PINECONE_API_KEY=
PINECONE_INDEX_NAME=lankside-schemes
PINECONE_ENVIRONMENT=
GRANT_SCOUT_USE_VECTOR=false
UPLOAD_DIR=/app/uploads
MOU_PDF_DIR=/app/uploads/mous
REPORT_OUTPUT_DIR=/app/uploads/reports
MAX_UPLOAD_SIZE_MB=10
ADMIN_DEMO_ENABLED=true
PYTHONUNBUFFERED=1
NEXT_TELEMETRY_DISABLED=1
